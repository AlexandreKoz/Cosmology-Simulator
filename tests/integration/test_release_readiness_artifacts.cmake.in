set(release_docs
  "@CMAKE_SOURCE_DIR@/RELEASE_NOTES.md"
  "@CMAKE_SOURCE_DIR@/docs/releases/initial_release_scope.md"
  "@CMAKE_SOURCE_DIR@/docs/releases/initial_release_validation_summary.md"
  "@CMAKE_SOURCE_DIR@/docs/releases/initial_release_benchmark_summary.md"
  "@CMAKE_SOURCE_DIR@/docs/releases/known_issues.md"
  "@CMAKE_SOURCE_DIR@/docs/releases/release_checklist.md"
  "@CMAKE_SOURCE_DIR@/release/release_manifest_v1.json")

foreach(release_file IN LISTS release_docs)
  if(NOT EXISTS "${release_file}")
    message(FATAL_ERROR "Missing release-readiness artifact: ${release_file}")
  endif()
endforeach()

file(READ "@CMAKE_SOURCE_DIR@/CMakePresets.json" cmake_presets_json)
foreach(required_preset IN ITEMS "cpu-only-debug" "cpu-only-release" "hdf5-debug" "pm-hdf5-fftw-debug" "mpi-release")
  if(NOT cmake_presets_json MATCHES "\"${required_preset}\"")
    message(FATAL_ERROR "CMakePresets.json is missing expected preset ${required_preset}")
  endif()
endforeach()

file(READ "@CMAKE_SOURCE_DIR@/src/core/harness_main.cpp" harness_main)
if(NOT harness_main MATCHES "loadFrozenConfigFromFile\\(")
  message(FATAL_ERROR "runtime executable must load config files through loadFrozenConfigFromFile(...)")
endif()
if(NOT harness_main MATCHES "ReferenceWorkflowRunner")
  message(FATAL_ERROR "runtime executable must construct the reference workflow runner")
endif()

file(READ "@CMAKE_SOURCE_DIR@/RELEASE_NOTES.md" release_notes)
if(NOT release_notes MATCHES "v0.1.0-initial")
  message(FATAL_ERROR "Release notes must include release id v0.1.0-initial")
endif()
if(NOT release_notes MATCHES "release_manifest_v1")
  message(FATAL_ERROR "Release notes must reference release_manifest_v1")
endif()
if(NOT release_notes MATCHES "real config-driven runtime application")
  message(FATAL_ERROR "Release notes must describe the real config-driven runtime path")
endif()
if(release_notes MATCHES "cosmosim_restart_v2")
  message(FATAL_ERROR "Release notes must not reference stale restart schema cosmosim_restart_v2")
endif()

file(READ "@CMAKE_SOURCE_DIR@/docs/releases/initial_release_scope.md" release_scope)
if(NOT release_scope MATCHES "zoom_in")
  message(FATAL_ERROR "Release scope must include zoom_in mode")
endif()
if(NOT release_scope MATCHES "experimental")
  message(FATAL_ERROR "Release scope must explicitly identify experimental paths")
endif()
if(NOT release_scope MATCHES "mpi-release")
  message(FATAL_ERROR "Release scope must use the current mpi-release preset name")
endif()
if(NOT release_scope MATCHES "pm-hdf5-fftw-debug")
  message(FATAL_ERROR "Release scope must use the current pm-hdf5-fftw-debug preset name")
endif()
if(release_scope MATCHES "`mpi-debug`" OR release_scope MATCHES "`fftw-debug`")
  message(FATAL_ERROR "Release scope contains stale preset names")
endif()

file(READ "@CMAKE_SOURCE_DIR@/docs/releases/initial_release_validation_summary.md" validation_summary)
if(validation_summary MATCHES "ctest -L unit" OR validation_summary MATCHES "ctest -L integration")
  message(FATAL_ERROR "Validation summary must not rely on misleading label-only shorthand")
endif()
if(NOT validation_summary MATCHES "integration_runtime_app_smoke")
  message(FATAL_ERROR "Validation summary must include the real runtime smoke gate")
endif()

file(READ "@CMAKE_SOURCE_DIR@/docs/configuration.md" config_doc)
if(NOT config_doc MATCHES "cosmosim_harness <config.param.txt>")
  message(FATAL_ERROR "Configuration docs must describe the real runtime CLI")
endif()
if(NOT config_doc MATCHES "<output.output_directory>/<output.run_name>")
  message(FATAL_ERROR "Configuration docs must describe the concrete config-driven run directory")
endif()

file(READ "@CMAKE_SOURCE_DIR@/docs/reference_workflow.md" workflow_doc)
if(NOT workflow_doc MATCHES "HierarchicalTimeBinScheduler")
  message(FATAL_ERROR "Reference workflow docs must describe live scheduler ownership")
endif()
if(NOT workflow_doc MATCHES "normalized_config.param.txt")
  message(FATAL_ERROR "Reference workflow docs must describe normalized_config.param.txt output")
endif()
if(NOT workflow_doc MATCHES "operational_events.json")
  message(FATAL_ERROR "Reference workflow docs must describe operational_events.json output")
endif()

file(READ "@CMAKE_SOURCE_DIR@/docs/validation_plan.md" validation_plan)
if(validation_plan MATCHES "Use `validation/input_decks/\\*.param.txt` for deterministic validation runs")
  message(FATAL_ERROR "Validation plan must not describe validation/input_decks as the runnable path")
endif()
if(NOT validation_plan MATCHES "integration_runtime_app_smoke")
  message(FATAL_ERROR "Validation plan must mention the real runtime smoke gate")
endif()

file(READ "@CMAKE_SOURCE_DIR@/release/release_manifest_v1.json" release_manifest)
if(NOT release_manifest MATCHES "\"manifest_schema\"[ \t]*:[ \t]*\"release_manifest_v1\"")
  message(FATAL_ERROR "Release manifest must declare release_manifest_v1 schema")
endif()
if(NOT release_manifest MATCHES "\"provenance_schema\"[ \t]*:[ \t]*\"provenance_v1\"")
  message(FATAL_ERROR "Release manifest must declare provenance_v1")
endif()
if(NOT release_manifest MATCHES "\"snapshot_schema\"[ \t]*:[ \t]*\"gadget_arepo_v1\"")
  message(FATAL_ERROR "Release manifest must declare gadget_arepo_v1 snapshot schema")
endif()
if(NOT release_manifest MATCHES "\"restart_schema\"[ \t]*:[ \t]*\"cosmosim_restart_v4\"")
  message(FATAL_ERROR "Release manifest must declare cosmosim_restart_v4 restart schema")
endif()
if(NOT release_manifest MATCHES "\"mpi\"[ \t]*:[ \t]*false")
  message(FATAL_ERROR "Release manifest must not overclaim MPI production readiness in this release gate")
endif()

set(release_configs
  "@CMAKE_SOURCE_DIR@/configs/release/release_smoke_zoom_in.param.txt"
  "@CMAKE_SOURCE_DIR@/configs/release/release_smoke_isolated_galaxy.param.txt"
  "@CMAKE_SOURCE_DIR@/configs/release/release_smoke_cosmo_cube.param.txt")

foreach(config_file IN LISTS release_configs)
  if(NOT EXISTS "${config_file}")
    message(FATAL_ERROR "Missing release example config: ${config_file}")
  endif()
  file(READ "${config_file}" config_text)
  if(NOT config_text MATCHES "schema_version[ \t]*=[ \t]*1")
    message(FATAL_ERROR "Release config must pin schema_version=1: ${config_file}")
  endif()
  if(NOT config_text MATCHES "coordinate_frame[ \t]*=[ \t]*comoving")
    message(FATAL_ERROR "Release config must declare comoving frame: ${config_file}")
  endif()
  if(NOT config_text MATCHES "output_directory")
    message(FATAL_ERROR "Release config must declare output_directory: ${config_file}")
  endif()
  if(NOT config_text MATCHES "output_stem")
    message(FATAL_ERROR "Release config must declare output_stem: ${config_file}")
  endif()
  if(NOT config_text MATCHES "restart_stem")
    message(FATAL_ERROR "Release config must declare restart_stem: ${config_file}")
  endif()
endforeach()
