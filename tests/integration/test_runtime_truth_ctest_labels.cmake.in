set(ctest_file "@CMAKE_BINARY_DIR@/CTestTestfile.cmake")
if(NOT EXISTS "${ctest_file}")
  message(FATAL_ERROR "CTest registration file missing: ${ctest_file}")
endif()

file(READ "${ctest_file}" ctest_content)

function(require_registered_runtime_truth_test test_name)
  string(REGEX MATCH "add_test\\(\\[=\\[${test_name}\\]=\\]" test_registration "${ctest_content}")
  if(NOT test_registration)
    message(FATAL_ERROR "P0 runtime-truth test is not registered with CTest: ${test_name}")
  endif()

  string(REGEX MATCH "set_tests_properties\\(\\[=\\[${test_name}\\]=\\] PROPERTIES[^\n]*LABELS \"([^\"]*)\"" test_properties "${ctest_content}")
  if(NOT test_properties)
    message(FATAL_ERROR "P0 runtime-truth test has no CTest LABELS property: ${test_name}")
  endif()

  set(test_labels ";${CMAKE_MATCH_1};")
  foreach(required_label IN LISTS ARGN)
    if(NOT test_labels MATCHES ";${required_label};")
      message(FATAL_ERROR "P0 runtime-truth test '${test_name}' missing label '${required_label}'. Labels were: ${CMAKE_MATCH_1}")
    endif()
  endforeach()
endfunction()

function(require_test_absent_when_feature_disabled test_name feature_name feature_enabled)
  if(NOT feature_enabled)
    string(REGEX MATCH "add_test\\(\\[=\\[${test_name}\\]=\\]" test_registration "${ctest_content}")
    if(test_registration)
      message(FATAL_ERROR "Feature-gated test '${test_name}' is registered even though ${feature_name} is disabled")
    endif()
  endif()
endfunction()

