# Guardrail: core layer must not include upward modules.
set(_forbidden_regex "#include[ \t]*[<\"]cosmosim/(analysis|io|physics|workflows|app)/")

file(GLOB_RECURSE _core_headers "@CMAKE_SOURCE_DIR@/include/cosmosim/core/*.hpp")
file(GLOB_RECURSE _core_sources "@CMAKE_SOURCE_DIR@/src/core/*.cpp")

set(_violations "")
foreach(_file IN LISTS _core_headers _core_sources)
  file(READ "${_file}" _content)
  string(REGEX MATCH "${_forbidden_regex}" _match "${_content}")
  if(_match)
    list(APPEND _violations "${_file}")
  endif()
endforeach()

if(_violations)
  list(JOIN _violations "\n  - " _joined)
  message(FATAL_ERROR
    "Core dependency-direction guard failed.\n"
    "The following core files include forbidden upward modules (analysis/io/physics/workflows/app):\n"
    "  - ${_joined}\n")
endif()

message(STATUS "Core dependency-direction include guard passed.")

# Guardrail: core target wiring must not link upward modules.
# This check uses CMake-generated graph metadata rather than source-text scans.
set(_graphviz_file "@CMAKE_BINARY_DIR@/core_dependency_graph.dot")
execute_process(
  COMMAND "@CMAKE_COMMAND@" "--graphviz=${_graphviz_file}" "@CMAKE_BINARY_DIR@"
  WORKING_DIRECTORY "@CMAKE_BINARY_DIR@"
  RESULT_VARIABLE _graphviz_result
  OUTPUT_VARIABLE _graphviz_stdout
  ERROR_VARIABLE _graphviz_stderr)

if(NOT _graphviz_result EQUAL 0)
  message(FATAL_ERROR
    "Core dependency-direction guard failed.\n"
    "Unable to generate CMake graphviz dependency graph from @CMAKE_BINARY_DIR@.\n"
    "stdout: ${_graphviz_stdout}\n"
    "stderr: ${_graphviz_stderr}")
endif()

file(READ "${_graphviz_file}" _graphviz_content)
string(REGEX MATCH "\"cosmosim_core\"[ \t]*->[ \t]*\"cosmosim_(analysis|io|physics|workflows|app)\"" _core_link_violation "${_graphviz_content}")
if(_core_link_violation)
  message(FATAL_ERROR
    "Core dependency-direction guard failed.\n"
    "CMake target graph links cosmosim_core to a forbidden upward module.\n"
    "Match: ${_core_link_violation}")
endif()

message(STATUS "Core CMake target-link guard passed via graphviz metadata.")

# Numerical modules must not depend upward on workflow composition.
set(_numerical_roots analysis amr gravity hydro io parallel physics)
set(_numerical_violations "")
foreach(_root IN LISTS _numerical_roots)
  file(GLOB_RECURSE _module_headers "@CMAKE_SOURCE_DIR@/include/cosmosim/${_root}/*.hpp")
  file(GLOB_RECURSE _module_sources "@CMAKE_SOURCE_DIR@/src/${_root}/*.cpp")
  foreach(_file IN LISTS _module_headers _module_sources)
    file(READ "${_file}" _content)
    string(REGEX MATCH "#include[ \t]*[<\"](cosmosim/)?workflows/" _match "${_content}")
    if(_match)
      list(APPEND _numerical_violations "${_file}")
    endif()
  endforeach()
endforeach()
if(_numerical_violations)
  list(JOIN _numerical_violations "\n  - " _joined)
  message(FATAL_ERROR
    "Numerical-to-workflow dependency guard failed:\n  - ${_joined}\n")
endif()
message(STATUS "Numerical modules do not include workflow composition.")

# Owner interfaces are public dependency seams; an owner may use shared
# workflow helpers but may not include another owner's private header.
set(_owner_sources
  "@CMAKE_SOURCE_DIR@/src/workflows/analysis_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/gravity_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/hydro_amr_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/migration_balance_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/output_restart_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/source_runtime.cpp"
  "@CMAKE_SOURCE_DIR@/src/workflows/time_coordinator.cpp")
set(_private_owner_regex
  "#include[ \t]*[<\"]workflows/internal/(initial_condition_runtime|migration_balance_runtime|output_restart_runtime|reference_runtime_composition)\\.hpp")
set(_owner_violations "")
foreach(_file IN LISTS _owner_sources)
  file(READ "${_file}" _content)
  string(REGEX MATCH "${_private_owner_regex}" _match "${_content}")
  if(_match)
    list(APPEND _owner_violations "${_file}")
  endif()
endforeach()
if(_owner_violations)
  list(JOIN _owner_violations "\n  - " _joined)
  message(FATAL_ERROR
    "Cross-owner private-header guard failed:\n  - ${_joined}\n")
endif()
message(STATUS "Owner services use public interfaces or shared helper seams.")
