set(source_dir "@CMAKE_SOURCE_DIR@")
set(current_build_has_hdf5 "@COSMOSIM_ENABLE_HDF5@")
set(current_build_has_fftw "@COSMOSIM_ENABLE_FFTW@")
set(current_build_has_python "@COSMOSIM_ENABLE_PYTHON@")

function(require_preset_configure preset_name)
  execute_process(
    COMMAND "@CMAKE_COMMAND@" --preset "${preset_name}"
    WORKING_DIRECTORY "${source_dir}"
    RESULT_VARIABLE preset_result
    OUTPUT_VARIABLE preset_stdout
    ERROR_VARIABLE preset_stderr)

  if(NOT preset_result EQUAL 0)
    message(FATAL_ERROR "${preset_name} preset configure failed:
${preset_stdout}
${preset_stderr}")
  endif()
endfunction()

require_preset_configure(cpu-only-debug)

if(current_build_has_hdf5)
  require_preset_configure(hdf5-debug)
endif()

if(current_build_has_hdf5 AND current_build_has_fftw)
  require_preset_configure(pm-hdf5-fftw-debug)
endif()

if(current_build_has_python)
  require_preset_configure(python-debug)
endif()
